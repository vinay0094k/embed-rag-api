# FastAPI
HOST=0.0.0.0
PORT=8000
ENV=development
API_VERSION=v1.0.0
DEBUG=False

# Database
DATABASE_URL=sqlite:///./rag_api.db
SQLALCHEMY_ECHO=false

# File Upload
MAX_FILE_SIZE_MB=50
ASYNC_THRESHOLD_MB=5
ALLOWED_EXTENSIONS=txt,md
TEMP_UPLOAD_DIR=./temp_uploads

# RAG
CHROMA_DB_PATH=./chroma_db
KNOWLEDGE_BASE_PATH=./knowledge_base
MAX_CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Embeddings
EMBEDDINGS_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2
EMBEDDINGS_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key-here
DEVICE=cpu

# Search
DEFAULT_TOP_K=5
SIMILARITY_THRESHOLD=0.5
HYBRID_SEARCH_ALPHA=0.5

# Query Expansion (LLM-based query variant generation)
QUERY_EXPANSION_ENABLED=false
QUERY_EXPANSION_NUM_VARIANTS=3
QUERY_EXPANSION_TIMEOUT=5.0
QUERY_EXPANSION_MODEL=openai/gpt-4o-mini

# Async Tasks (Celery)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security (MUST be set in production)
SECRET_KEY=your-secret-key-here-min-32-chars
API_KEY_PREFIX=sk_rag_
API_KEY_LENGTH=32

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# Debug mode (false in production)
DEBUG=false
